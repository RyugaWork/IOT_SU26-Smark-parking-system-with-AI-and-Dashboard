# Core server behavior
MODEL_PATH=yolov8n.pt
CONF_THRESHOLD=0.45
IMG_SIZE=640
ALLOWED_CLASSES=car,motorcycle,bus,truck
SAVE_RAW_IMAGE=1
SAVE_RESULT_IMAGE=1
RESULT_DIR=results

# Database mode
# Keep 0 for Arduino/ESP32-CAM testing without SQL Server.
DB_ENABLED=0
DB_FAIL_SAFE_CLOSE=0

# SQL Server settings, used only when DB_ENABLED=1
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_NAME=SmartParkingIOT102
DB_USER=sa
DB_PASSWORD=12345
DB_ENCRYPT=no
DB_TRUST_SERVER_CERTIFICATE=yes

# Optional full connection string. If set, it overrides the individual DB_* values.
# DB_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost,1433;DATABASE=SmartParkingIOT102;UID=sa;PWD=12345;Encrypt=no;TrustServerCertificate=yes;
